# Cross-Platform Line Ending Configuration for YYC³ Family-PAI
# Ensures consistent behavior across Windows, macOS, and Linux

* text=auto

# Text files
*.md text
*.json text
*.js text
*.ts text
*.tsx text
*.mjs text
*.mts text
*.cts text
*.yml text
*.yaml text
*.txt text
*.html text
*.css text
*.scss text
*.xml text
*.config text
*.gitignore text
*.gitattributes text

# Shell scripts always LF
*.sh text eol=lf
*.bash text eol=lf

# Windows batch files CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# Node.js files
package.json text
package-lock.json text
pnpm-lock.yaml text
.nvmrc text
.node-version text

# Git files
.gitignore text
.gitattributes text

# Config files
tsconfig.json text
tsconfig.*.json text
.eslintrc* text
.prettierrc* text
*.config.js text
*.config.ts text

# Documentation
README* text
LICENSE* text
CHANGELOG* text
CONTRIBUTING* text

# Sensitive files
*.env text
*.key binary
*.pem binary
*.p12 binary
*.pfx binary

# Generated / cache directories
node_modules/** binary
dist/** binary
coverage/** binary
