#!/usr/bin/env sh

echo "🔍 Running pre-commit checks..."

CHANGED=$(git diff --cached --name-only --diff-filter=ACM | grep "^packages/" | cut -d'/' -f2 | sort -u)

if [ -z "$CHANGED" ]; then
  echo "ℹ️  No package changes detected, skipping package checks."
  exit 0
fi

for pkg in $CHANGED; do
  if [ -d "packages/$pkg" ] && [ -f "packages/$pkg/package.json" ]; then
    echo "🔎 Linting packages/$pkg..."
    pnpm -C "packages/$pkg" lint || {
      echo "❌ Lint failed for packages/$pkg"
      exit 1
    }
  fi
done

echo "✅ Pre-commit checks passed!"
