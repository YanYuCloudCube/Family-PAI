#!/usr/bin/env sh

COMMIT_MSG_FILE=$1

if [ ! -f "$COMMIT_MSG_FILE" ]; then
  exit 0
fi

sed -i '' '/^🤖 Generated with \[Claude Code\]/d' "$COMMIT_MSG_FILE" 2>/dev/null || \
  sed -i '/^🤖 Generated with \[Claude Code\]/d' "$COMMIT_MSG_FILE" 2>/dev/null || true

sed -i '' '/^Co-Authored-By: Claude/d' "$COMMIT_MSG_FILE" 2>/dev/null || \
  sed -i '/^Co-Authored-By: Claude/d' "$COMMIT_MSG_FILE" 2>/dev/null || true

sed -i '' -e :a -e '/^\n*$/{$d;N;ba' -e '}' "$COMMIT_MSG_FILE" 2>/dev/null || \
  sed -i -e :a -e '/^\n*$/{$d;N;ba' -e '}' "$COMMIT_MSG_FILE" 2>/dev/null || true
