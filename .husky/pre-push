#!/usr/bin/env sh

echo "🔍 Running pre-push validation..."
echo ""

echo "1/5 Type checking all packages..."
pnpm -r typecheck || { echo "❌ Type checking failed"; exit 1; }

echo ""
echo "2/5 Linting all packages..."
pnpm -r lint || { echo "❌ Linting failed"; exit 1; }

echo ""
echo "3/5 Running tests..."
pnpm -r test || { echo "❌ Tests failed"; exit 1; }

echo ""
echo "4/5 Building all packages..."
pnpm -r build || { echo "❌ Build failed"; exit 1; }

echo ""
echo "5/5 Optional quality checks (non-blocking)..."
echo "   💡 Run manually before release:"
echo "      pnpm -r exec size-limit"
echo "      npx license-checker --production --failOn 'GPL;LGPL;AGPL'"

echo ""
echo "✅ All pre-push validation passed!"
echo ""
